{
  "name": "portfolio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "emdash": {
    "label": "Portfolio",
    "seed": "seed/seed.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy --config wrangler.prod.jsonc",
    "bootstrap": "npx emdash init && npx emdash seed seed/seed.json",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@abdulrysr/saudi-riyal-new-symbol-font": "^1.0.8",
    "@astrojs/react": "^5.0.0",
    "@emdash-cms/auth-atproto": "^0.2.13",
    "@emdash-cms/cloudflare": "0.17.2",
    "@emdash-cms/plugin-forms": "0.2.3",
    "@emdash-cms/plugin-webhook-notifier": "0.2.0",
    "agents": "^0.11.0",
    "astro": "^6.1.2",
    "emdash": "0.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/cloudflare": "13.1.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "wrangler": "4.81.1"
  },
  "pnpm": {
    "overrides": {
      "@cloudflare/vite-plugin": "1.31.2"
    },
    "patchedDependencies": {
      "emdash@0.17.2": "patches/emdash@0.17.2.patch"
    }
  }
}
