---
import { Font } from "astro:assets";
import { getMenu, getSiteSettings, getEmDashCollection } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd, WidgetArea } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { getDir, getLocaleFromPath, t, type Locale, defaultLocale } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** Current locale */
	locale?: Locale;
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	locale: localeProp,
} = Astro.props;

// Determine locale from prop or URL
const locale: Locale = localeProp || getLocaleFromPath(Astro.url.pathname) || defaultLocale;
const dir = getDir(locale);
const isRTL = dir === "rtl";
const [settings, _menu, { entries: pages }] = await Promise.all([
	getSiteSettings(),
	getMenu("primary"),
	getEmDashCollection("pages"),
]);
const siteTitle = settings?.title || "Studio";
const siteDescription = settings?.tagline || "Design & Development";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;

const isLoggedIn = !!Astro.locals.user;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description: description || siteDescription,
	canonical: canonical ?? Astro.url.href,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// hreflang: strip locale prefix then build per-locale hrefs
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(ar|en)/, "") || "/";
const hrefAr = `${Astro.url.origin}/ar${pathWithoutLocale === "/" ? "" : pathWithoutLocale}`;
const hrefEn = `${Astro.url.origin}/en${pathWithoutLocale === "/" ? "" : pathWithoutLocale}`;

// JSON-LD
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: siteTitle,
	url: Astro.url.origin,
};
const articleSchema =
	type === "article" && publishedTime
		? {
				"@context": "https://schema.org",
				"@type": "BlogPosting",
				headline: title ?? fullTitle,
				url: canonical ?? Astro.url.href,
				datePublished: publishedTime,
				dateModified: modifiedTime ?? publishedTime,
				description: description ?? siteDescription,
				...(image ? { image } : {}),
				author: {
					"@type": "Person",
					name: author ?? siteTitle,
				},
			}
		: null;
---

<!doctype html>
<html lang={locale} dir={dir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<link rel="alternate" hreflang="ar" href={hrefAr} />
		<link rel="alternate" hreflang="en" href={hrefEn} />
		<link rel="alternate" hreflang="x-default" href={hrefAr} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
		<Font cssVariable="--font-playfair" preload />
		<Font cssVariable="--font-jetbrains" preload />
		<Font cssVariable="--font-amiri" />
		<Font cssVariable="--font-cairo" />
		<link rel="preconnect" href="https://cdn.engdawood.com" crossorigin />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} RSS Feed`}
			href="/rss.xml"
		/>
		<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header">
			<nav class="nav">
				<a href={`/${locale}`} class="site-logo" dir="ltr" aria-label="Home">
					<svg width="44" height="34" viewBox="0 0 44 34" class="logo-mark" aria-hidden="true">
						<text x="0" y="30" font-family="'Playfair Display', serif" font-size="40" font-weight="400" fill="var(--color-text)" letter-spacing="-0.06em">D</text>
						<text x="17" y="30" font-family="'Playfair Display', serif" font-size="40" font-weight="400" font-style="italic" fill="var(--color-accent)" letter-spacing="-0.06em">s</text>
						<circle cx="40" cy="29" r="1.6" fill="var(--color-accent)" />
					</svg>
					<div class="logo-wordmark">
						<span class="logo-name">Dawood Saleh</span>
						<span class="logo-sub">{t("hero.role", locale)}</span>
					</div>
				</a>
				<div class="nav-right">
					<div class="nav-links">
						<a href={`/${locale}/work`}>{t("nav.projects", locale)}</a>
						<a href={`/${locale}/posts`}>{t("nav.blog", locale)}</a>
						<a href={`/${locale}#about`}>{t("nav.about", locale)}</a>
						<a href={`/${locale}#contact`}>{t("nav.contact", locale)}</a>
					</div>
					<LiveSearch
						placeholder={t("search.placeholder", locale)}
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["projects", "posts", "pages"]}
					/>
					<button
						type="button"
						id="theme-toggle"
						class="theme-toggle-btn"
						aria-label="Toggle dark mode"
					>
						<svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
						<svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
					</button>
					<LanguageSwitcher locale={locale} />
					{isLoggedIn && <a href="/tracker" class="nav-admin">Tracker</a>}
					{isLoggedIn ? (
						<a href="/_emdash/admin" class="nav-admin">Admin</a>
					) : (
						<a href="/_emdash/admin" class="nav-admin">Login</a>
					)}
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href={`/${locale}`} class="footer-logo-wrap" dir="ltr">
							<svg width="52" height="40" viewBox="0 0 52 40" class="footer-logo-mark" aria-hidden="true">
								<text x="0" y="35" font-family="'Playfair Display', serif" font-size="46" font-weight="400" fill="var(--color-text)" letter-spacing="-0.06em">D</text>
								<text x="19" y="35" font-family="'Playfair Display', serif" font-size="46" font-weight="400" font-style="italic" fill="var(--color-accent)" letter-spacing="-0.06em">s</text>
								<circle cx="47" cy="33" r="1.8" fill="var(--color-accent)" />
							</svg>
							<div class="footer-logo-text">
								<span class="footer-logo-name">{siteTitle}</span>
								<span class="footer-logo-sub">{t("footer.tagline", locale)}</span>
							</div>
						</a>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{t("footer.nav", locale)}</h4>
						<ul class="footer-links">
							<li><a href={`/${locale}`}>{t("nav.home", locale)}</a></li>
							<li><a href={`/${locale}/work`}>{t("nav.projects", locale)}</a></li>
							<li><a href={`/${locale}/posts`}>{t("nav.blog", locale)}</a></li>
							{
								pages.slice(0, 2).map((page) => (
									<li>
										<a href={`/${locale}/pages/${page.data.slug || page.id}`}>
											{page.data.title}
										</a>
									</li>
								))
							}
						</ul>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{t("footer.connect", locale)}</h4>
						<ul class="footer-links">
							<li><a href={`/${locale}#contact`}>{t("nav.contact", locale)}</a></li>
							<li><a href="/rss.xml">{t("footer.rss", locale)}</a></li>
						</ul>
					</div>
					<div class="footer-widgets-section">
						<div class="footer-widget">
							<h4 class="footer-heading">{t("footer.aboutHeading", locale)}</h4>
							<p class="footer-about-text" style="color: var(--color-text-secondary); font-size: var(--font-size-sm); line-height: var(--leading-relaxed);">
								{t("footer.aboutText", locale)}
							</p>
						</div>
					</div>
				</div>
				<div class="footer-bottom">
					<p class="footer-copyright">
						&copy; {new Date().getFullYear()} {t("footer.copyright", locale)}
					</p>
					<div class="theme-switcher">
						<button
							type="button"
							class="theme-btn"
							data-theme="light"
							aria-label="Light mode">{t("theme.light", locale)}</button
						>
						<button
							type="button"
							class="theme-btn"
							data-theme="dark"
							aria-label="Dark mode">{t("theme.dark", locale)}</button
						>
						<button
							type="button"
							class="theme-btn"
							data-theme="system"
							aria-label="System theme">{t("theme.system", locale)}</button
						>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Theme switcher
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns =
				document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const root = document.documentElement;

			function setTheme(theme: string) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (theme === "system") {
					document.cookie = `theme=; path=/; max-age=0; SameSite=Lax${secure}`;
					root.classList.remove("light", "dark");
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						root.classList.add("dark");
					}
				} else {
					document.cookie = `theme=${theme}; path=/; max-age=31536000; SameSite=Lax${secure}`;
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "system";
			}

			// Initialize - apply stored theme on load
			const storedTheme = getStoredTheme();
			setTheme(storedTheme);

			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					setTheme(btn.dataset.theme || "system");
				});
			});

			// Nav toggle button
			const toggleBtn = document.getElementById("theme-toggle");
			if (toggleBtn) {
				toggleBtn.addEventListener("click", () => {
					const isDark = document.documentElement.classList.contains("dark");
					setTheme(isDark ? "light" : "dark");
				});
			}

			// Listen for system preference changes
			window
				.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (e) => {
					if (getStoredTheme() === "system") {
						root.classList.toggle("dark", e.matches);
					}
				});
		</script>

		<style is:global>
@font-face {
				font-family: "Thmanyah Sans";
				src: local("Thmanyah Sans"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-sans/woff2/thmanyah-sans-Light.woff2") format("woff2");
				font-weight: 300;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Sans";
				src: local("Thmanyah Sans"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-sans/woff2/thmanyah-sans-Regular.woff2") format("woff2");
				font-weight: 400;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Sans";
				src: local("Thmanyah Sans"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-sans/woff2/thmanyah-sans-Medium.woff2") format("woff2");
				font-weight: 500;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Sans";
				src: local("Thmanyah Sans"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-sans/woff2/thmanyah-sans-Bold.woff2") format("woff2");
				font-weight: 700;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Sans";
				src: local("Thmanyah Sans"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-sans/woff2/thmanyah-sans-Black.woff2") format("woff2");
				font-weight: 900;
				font-style: normal;
				font-display: swap;
			}

			@font-face {
				font-family: "Al Jazeera";
				src: local("Al Jazeera"),
					url("https://cdn.engdawood.com/fonts/Al-Jazeera/Al-Jazeera-Light.b09a8096.woff2") format("woff2");
				font-weight: 300;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Al Jazeera";
				src: local("Al Jazeera"),
					url("https://cdn.engdawood.com/fonts/Al-Jazeera/Al-Jazeera-Regular.0112de0f.woff2") format("woff2");
				font-weight: 400;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Al Jazeera";
				src: local("Al Jazeera"),
					url("https://cdn.engdawood.com/fonts/Al-Jazeera/Al-Jazeera-Bold.3301c4f5.woff2") format("woff2");
				font-weight: 700;
				font-style: normal;
				font-display: swap;
			}

			@font-face {
				font-family: "Thmanyah Serif Display";
				src: local("Thmanyah Serif Display"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-display/woff2/thmanyah-serif-display-Light.woff2") format("woff2");
				font-weight: 300;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Display";
				src: local("Thmanyah Serif Display"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-display/woff2/thmanyah-serif-display-Regular.woff2") format("woff2");
				font-weight: 400;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Display";
				src: local("Thmanyah Serif Display"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-display/woff2/thmanyah-serif-display-Medium.woff2") format("woff2");
				font-weight: 500;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Display";
				src: local("Thmanyah Serif Display"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-display/woff2/thmanyah-serif-display-Bold.woff2") format("woff2");
				font-weight: 700;
				font-style: normal;
				font-display: swap;
			}

			@font-face {
				font-family: "Thmanyah Serif Text";
				src: local("Thmanyah Serif Text"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-text/woff2/thmanyah-serif-text-Light.woff2") format("woff2");
				font-weight: 300;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Text";
				src: local("Thmanyah Serif Text"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-text/woff2/thmanyah-serif-text-Regular.woff2") format("woff2");
				font-weight: 400;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Text";
				src: local("Thmanyah Serif Text"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-text/woff2/thmanyah-serif-text-Medium.woff2") format("woff2");
				font-weight: 500;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Thmanyah Serif Text";
				src: local("Thmanyah Serif Text"),
					url("https://cdn.engdawood.com/fonts/Thmanyah-Font-Family/thmanyah-serif-text/woff2/thmanyah-serif-text-Bold.woff2") format("woff2");
				font-weight: 700;
				font-style: normal;
				font-display: swap;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			:root {
				/* Colors - Editorial warm palette */
				--color-bg: #f8f5ef;
				--color-bg-subtle: #f2ede3;
				--color-text: #16130e;
				--color-text-secondary: #4a4438;
				--color-muted: #8a8374;
				--color-border: #d9d2c3;
				--color-border-subtle: #ede7d8;
				--color-surface: #fdfbf6;
				--color-accent: #6b1438;
				--color-accent-hover: #4a0d26;
				--color-accent-muted: #a0364e;
				--color-on-accent: #fdfbf6;
				--color-accent-ring: color-mix(in srgb, var(--color-accent) 20%, transparent);

				/* EmDash search theming */
				--emdash-search-bg: var(--color-bg);
				--emdash-search-text: var(--color-text);
				--emdash-search-muted: var(--color-muted);
				--emdash-search-border: var(--color-border);
				--emdash-search-hover: var(--color-surface);
				--emdash-search-highlight: var(--color-text);

				/* Typography */
				--font-serif: var(--font-playfair), Georgia, serif;
				--font-sans: system-ui, -apple-system, sans-serif;
				--font-arabic: "Thmanyah Serif Text", "Al Jazeera", var(--font-cairo), serif;
				--font-arabic-heading: "Thmanyah Serif Display", "Thmanyah Serif Text", "Al Jazeera", serif;
				--font-arabic-sans: "Thmanyah Sans", "Al Jazeera", var(--font-cairo), sans-serif;
				--font-mono: var(--font-jetbrains), ui-monospace, monospace;

				--font-size-xs: 0.75rem;
				--font-size-sm: 0.875rem;
				--font-size-base: 1.0625rem;
				--font-size-lg: 1.25rem;
				--font-size-xl: 1.5rem;
				--font-size-2xl: 2rem;
				--font-size-3xl: 2.75rem;
				--font-size-4xl: 3.5rem;
				--font-size-5xl: 4.5rem;

				/* Line heights */
				--leading-tight: 1.15;
				--leading-snug: 1.3;
				--leading-normal: 1.5;
				--leading-relaxed: 1.7;

				/* Spacing */
				--spacing-1: 0.25rem;
				--spacing-2: 0.5rem;
				--spacing-3: 0.75rem;
				--spacing-4: 1rem;
				--spacing-5: 1.25rem;
				--spacing-6: 1.5rem;
				--spacing-8: 2rem;
				--spacing-10: 2.5rem;
				--spacing-12: 3rem;
				--spacing-16: 4rem;
				--spacing-20: 5rem;
				--spacing-24: 6rem;

				/* Legacy spacing aliases */
				--spacing-xs: var(--spacing-1);
				--spacing-sm: var(--spacing-2);
				--spacing-md: var(--spacing-4);
				--spacing-lg: var(--spacing-6);
				--spacing-xl: var(--spacing-8);
				--spacing-2xl: var(--spacing-12);
				--spacing-3xl: var(--spacing-16);
				--spacing-4xl: var(--spacing-24);

				/* Layout */
				--content-width: 680px;
				--max-width: 720px;
				--wide-width: 1200px;
				--gutter-width: 200px;
				--meta-col-width: 180px;
				--radius: 4px;
				--radius-lg: 8px;

				/* Nav */
				--nav-height: 64px;
				--search-input-width: 180px;

				/* Letter spacing */
				--tracking-tight: -0.03em;
				--tracking-snug: -0.02em;
				--tracking-wide: 0.06em;
				--tracking-wider: 0.08em;

				/* Tag pill */
				--tag-padding-y: 2px;

				/* Avatars */
				--avatar-size-xs: 18px;
				--avatar-size-sm: 20px;
				--avatar-size-md: 24px;
				--avatar-size-lg: 32px;

				/* Shadows */
				--shadow-dropdown: 0 8px 30px rgba(0, 0, 0, 0.12);
				--shadow-btn-active: 0 1px 2px rgba(0, 0, 0, 0.05);

				/* Transitions */
				--transition-fast: 150ms ease;
				--transition-base: 200ms ease;
				--transition-slow: 300ms ease;
			}

			/* Dark mode via system preference (when no explicit class) */
			@media (prefers-color-scheme: dark) {
				:root:not(.light) {
					--color-bg: #0e0d0b;
					--color-bg-subtle: #141210;
					--color-text: #f4efe3;
					--color-text-secondary: #a89e8c;
					--color-muted: #80796a;
					--color-border: #2a2721;
					--color-border-subtle: #231f1a;
					--color-surface: #18130e;
					--color-accent: #9b2346;
					--color-accent-hover: #b8284f;
					--color-accent-muted: #6b1438;
				}
			}

			/* Explicit dark mode */
			:root.dark {
				--color-bg: #0e0d0b;
				--color-bg-subtle: #141210;
				--color-text: #f4efe3;
				--color-text-secondary: #a89e8c;
				--color-muted: #80796a;
				--color-border: #2a2721;
				--color-border-subtle: #231f1a;
				--color-surface: #18130e;
				--color-accent: #9b2346;
				--color-accent-hover: #b8284f;
				--color-accent-muted: #6b1438;
				--color-on-accent: #fdfbf6;
				--shadow-dropdown: 0 8px 30px rgba(0, 0, 0, 0.45);
				--shadow-btn-active: 0 1px 2px rgba(0, 0, 0, 0.3);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: 1.6;
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				min-height: 100vh;
			}

			/* RTL (Arabic) styles */
			html[dir="rtl"] {
				font-family: var(--font-arabic);
			}

			html[dir="rtl"] body {
				font-family: var(--font-arabic);
				font-size: calc(var(--font-size-base) * 1.02);
				line-height: 1.7;
			}

			html[dir="rtl"] h1,
			html[dir="rtl"] h2,
			html[dir="rtl"] h3,
			html[dir="rtl"] h4 {
				font-family: var(--font-arabic-heading);
				letter-spacing: 0;
			}

			/* Flip flex direction for RTL */
			html[dir="rtl"] .nav,
			html[dir="rtl"] .nav-right,
			html[dir="rtl"] .nav-links {
				flex-direction: row-reverse;
			}

			html[dir="rtl"] .nav-links a,
			html[dir="rtl"] .nav-admin,
			html[dir="rtl"] .footer-links a,
			html[dir="rtl"] .footer-heading {
				font-family: var(--font-arabic-heading);
			}

			html[dir="rtl"] .footer-grid {
				direction: rtl;
			}

			html[dir="rtl"] .footer-logo-sub,
			html[dir="rtl"] .logo-sub {
				font-family: var(--font-arabic);
				font-style: normal;
			}

			a {
				color: currentColor;
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1,
			h2,
			h3,
			h4 {
				font-family: var(--font-serif);
				font-weight: 500;
				line-height: 1.2;
			}

			h1 {
				font-size: var(--font-size-4xl);
			}

			h2 {
				font-size: var(--font-size-2xl);
			}

			h3 {
				font-size: var(--font-size-xl);
			}
		</style>

		<style>
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: color-mix(in srgb, var(--color-bg) 80%, transparent);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border-bottom: 1px solid var(--color-border);
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-4) var(--spacing-6);
				height: var(--nav-height);
			}

			.site-logo {
				display: flex;
				flex-direction: row;
				align-items: center;
				gap: 12px;
				text-decoration: none;
				flex-shrink: 0;
			}

			.logo-mark {
				display: block;
				overflow: visible;
			}

			.logo-wordmark {
				display: flex;
				flex-direction: column;
				gap: 1px;
				line-height: 1.1;
			}

			.logo-name {
				font-family: var(--font-serif);
				font-size: 23px;
				font-weight: 500;
				color: var(--color-text);
				letter-spacing: -0.02em;
			}

			.logo-sub {
				font-family: var(--font-serif);
				font-size: 13px;
				font-style: italic;
				color: var(--color-muted);
			}

			.nav-right {
				display: flex;
				align-items: center;
				gap: var(--spacing-6);
			}

			.nav-links {
				display: flex;
				gap: var(--spacing-6);
				font-family: var(--font-mono);
				font-size: 17px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.nav-links a {
				text-decoration: none;
				color: var(--color-muted);
				transition: color var(--transition-fast);
			}

			.nav-links a:hover {
				color: var(--color-text);
			}

			.nav-admin {
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				text-decoration: none;
				opacity: 0.5;
				transition: opacity var(--transition-fast);
			}

			.nav-admin:hover {
				opacity: 1;
			}

			/* Search */
			.site-search {
				position: relative;
				width: var(--search-input-width);
				--emdash-search-border-focus: var(--color-accent);
			}

			:global(.site-search-input) {
				width: var(--search-input-width);
				padding: var(--spacing-2) var(--spacing-3);
				font-family: var(--font-sans);
				font-size: var(--font-size-sm);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				background: var(--color-bg);
				color: var(--color-text);
				transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
			}

			:global(.site-search-input)::placeholder {
				color: var(--color-muted);
			}

			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border-color: var(--color-accent) !important;
				box-shadow: 0 0 0 3px var(--color-accent-ring);
			}

			:global(.site-search-results) {
				position: absolute;
				top: 100%;
				left: 0;
				right: 0;
				margin-top: var(--spacing-2);
				background: var(--color-bg);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-dropdown);
				max-height: 400px;
				overflow-y: auto;
				z-index: 1000;
			}

			:global(.site-search-result) {
				display: block;
				padding: var(--spacing-3) var(--spacing-4);
				text-decoration: none;
				color: var(--color-text);
				border-bottom: 1px solid var(--color-border-subtle);
				transition: background var(--transition-fast);
			}

			:global(.site-search-result):last-child {
				border-bottom: none;
			}

			:global(.site-search-result):hover,
			:global(.site-search-result.focused) {
				background: var(--color-surface);
			}

			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-weight: 500;
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-size: var(--font-size-xs);
				color: var(--color-muted);
				text-transform: uppercase;
				letter-spacing: var(--tracking-wide);
				margin-top: 2px;
			}

			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				margin-top: var(--spacing-1);
			}

			main {
				min-height: calc(100vh - var(--nav-height) - 300px);
			}

			/* Footer */
			.site-footer {
				background: var(--color-bg-subtle);
				border-top: 1px solid var(--color-border);
			}

			.footer-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-16) var(--spacing-6) var(--spacing-8);
			}

			.footer-grid {
				display: grid;
				grid-template-columns: 2fr 1fr 1fr 1fr;
				gap: var(--spacing-12);
				margin-bottom: var(--spacing-12);
			}

			.footer-brand {
				max-width: 280px;
			}

			.footer-logo-wrap {
				display: flex;
				flex-direction: row;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.footer-logo-mark {
				display: block;
				overflow: visible;
				flex-shrink: 0;
			}

			.footer-logo-text {
				display: flex;
				flex-direction: column;
				gap: 3px;
			}

			.footer-logo-name {
				font-family: var(--font-serif);
				font-size: var(--font-size-lg);
				font-weight: 500;
				color: var(--color-text);
				letter-spacing: -0.02em;
			}

			.footer-logo-sub {
				font-family: var(--font-serif);
				font-style: italic;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
			}

			.footer-nav {
				min-width: 0;
			}

			.footer-heading {
				font-size: var(--font-size-xs);
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: var(--tracking-wider);
				color: var(--color-muted);
				margin-bottom: var(--spacing-4);
			}

			.footer-links {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.footer-links li {
				margin-bottom: var(--spacing-2);
			}

			.footer-links a {
				color: var(--color-text-secondary);
				text-decoration: none;
				font-size: var(--font-size-sm);
				transition: color var(--transition-fast);
			}

			.footer-links a:hover {
				color: var(--color-text);
			}

			.footer-widgets-section :global(.widget-area) {
				display: block;
			}

			.footer-widgets-section :global(.widget__title) {
				font-size: var(--font-size-xs);
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: var(--tracking-wider);
				color: var(--color-muted);
				margin-bottom: var(--spacing-4);
			}

			.footer-widgets-section :global(.widget__content) {
				color: var(--color-text-secondary);
				font-size: var(--font-size-sm);
				line-height: var(--leading-relaxed);
			}

			.footer-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding-top: var(--spacing-6);
				border-top: 1px solid var(--color-border);
			}

			.footer-copyright {
				font-size: var(--font-size-sm);
				color: var(--color-muted);
			}

			.footer-copyright a {
				color: var(--color-text-secondary);
				text-decoration: none;
			}

			.theme-toggle-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				color: var(--color-muted);
				cursor: pointer;
				transition: all var(--transition-fast);
				flex-shrink: 0;
			}

			.theme-toggle-btn:hover {
				color: var(--color-text);
				border-color: var(--color-accent);
			}

			/* Show/hide sun and moon based on current theme */
			#icon-moon { display: none; }
			:root.dark #icon-sun { display: none; }
			:root.dark #icon-moon { display: block; }

			.theme-switcher {
				display: flex;
				gap: var(--spacing-xs);
			}

			.theme-btn {
				background: transparent;
				border: 1px solid var(--color-border);
				color: var(--color-muted);
				font-family: var(--font-sans);
				font-size: var(--font-size-sm);
				padding: var(--spacing-xs) var(--spacing-sm);
				border-radius: var(--radius);
				cursor: pointer;
				transition: all var(--transition-fast);
			}

			.theme-btn:hover {
				color: var(--color-text);
				border-color: var(--color-text);
			}

			.theme-btn.active {
				background: var(--color-surface);
				color: var(--color-text);
				border-color: var(--color-accent);
			}

			@media (max-width: 900px) {
				.footer-grid {
					grid-template-columns: 1fr 1fr;
					gap: var(--spacing-8);
				}

				.footer-brand {
					grid-column: span 2;
					max-width: none;
				}
			}

			@media (max-width: 640px) {
				.nav {
					height: auto;
					flex-wrap: wrap;
					gap: var(--spacing-2);
					padding: var(--spacing-3) var(--spacing-4);
				}

				.nav-right {
					display: contents;
				}

				.site-search {
					order: 0;
					max-width: 130px;
				}

				:global(.site-search-input) {
					width: 130px !important;
				}

				.nav-links {
					order: 1;
					width: 100%;
					flex-wrap: wrap;
					gap: var(--spacing-3);
				}

				.nav-admin {
					order: 2;
				}

				.footer-grid {
					grid-template-columns: 1fr;
				}

				.footer-brand {
					grid-column: span 1;
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-4);
					text-align: center;
				}

				h1 {
					font-size: var(--font-size-3xl);
				}
			}
		</style>
		<script>
			// ⌘K / Ctrl+K to focus search
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".site-search-input"
					) as HTMLInputElement;
					if (searchInput) searchInput.focus();
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
