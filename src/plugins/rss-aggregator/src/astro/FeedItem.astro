---
import type { FeedItem, Display } from "../types";

interface Props {
	item: FeedItem;
	display: Display;
}

const { item, display } = Astro.props;

// Date formatter
const formattedDate = (() => {
	if (!item.publishedAt) return "";
	if (display.useRelativeDate) {
		const date = new Date(item.publishedAt);
		const diffMs = Date.now() - date.getTime();
		const seconds = Math.floor(diffMs / 1000);
		const minutes = Math.floor(seconds / 60);
		const hours = Math.floor(minutes / 60);
		const days = Math.floor(hours / 24);

		if (seconds < 60) return "just now";
		if (minutes < 60) return `${minutes}m ago`;
		if (hours < 24) return `${hours}h ago`;
		return `${days}d ago`;
	}

	// Simple format fallback (E.g. Jun 20, 2026)
	return new Date(item.publishedAt).toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});
})();

// Truncate title helper
const titleText = (() => {
	if (display.titleMaxLength > 0 && item.title.length > display.titleMaxLength) {
		return item.title.slice(0, display.titleMaxLength).trim() + "...";
	}
	return item.title;
})();

const linkTarget = display.linkTarget || "_blank";
const linkRel = display.linksNoFollow ? "nofollow noopener noreferrer" : "noopener noreferrer";

// Image handling
const showImage = display.enableImages && (item.imageUrl || (display.fallbackToSourceImage && item.imageUrl));
---

<div class={`rss-item ${display.layout}-item ${display.gridUseImageAsBg && display.layout === 'grid' ? 'bg-image-card' : ''}`} style={display.gridUseImageAsBg && display.layout === 'grid' && item.imageUrl ? `background-image: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.85) 100%), url(${item.imageUrl});` : ""}>
	{showImage && !display.gridUseImageAsBg && (
		<div class="rss-media-wrapper">
			{display.linkImages ? (
				<a href={item.url} target={linkTarget} rel={linkRel} class="rss-image-link">
					<img 
						src={item.imageUrl} 
						alt={item.title} 
						width={display.imageWidth || 150} 
						height={display.imageHeight || 150}
						style={`object-fit: ${display.gridFitImages ? 'cover' : 'contain'};`}
					/>
				</a>
			) : (
				<img 
					src={item.imageUrl} 
					alt={item.title} 
					width={display.imageWidth || 150} 
					height={display.imageHeight || 150}
					style={`object-fit: ${display.gridFitImages ? 'cover' : 'contain'};`}
				/>
			)}
		</div>
	)}

	<div class="rss-content-wrapper">
		{display.enableTitles && (
			<h3 class="rss-item-title">
				{display.linkTitles ? (
					<a href={item.url} target={linkTarget} rel={linkRel}>{titleText}</a>
				) : (
					<span>{titleText}</span>
				)}
			</h3>
		)}

		{/* Meta metadata row */}
		{(display.enableSources || display.enableDates || display.enableAuthors) && (
			<div class="rss-item-meta">
				{display.enableSources && item.sourceName && (
					<span class="rss-meta-source">
						{display.sourcePrefix}
						{display.linkSource && item.sourceUrl ? (
							<a href={item.sourceUrl} target="_blank" rel="noopener noreferrer">{item.sourceName}</a>
						) : (
							<span>{item.sourceName}</span>
						)}
					</span>
				)}

				{display.enableDates && formattedDate && (
					<span class="rss-meta-date">
						{display.datePrefix}{formattedDate}
					</span>
				)}

				{display.enableAuthors && item.author?.name && (
					<span class="rss-meta-author">
						{display.authorPrefix}{item.author.name}
					</span>
				)}
			</div>
		)}

		{/* YouTube Embed */}
		{display.layout === 'grid' && display.gridEnableEmbeds && item.youtubeVideoId && (
			<div class="rss-video-embed">
				<iframe
					src={`https://www.youtube.com/embed/${item.youtubeVideoId}`}
					title={item.title}
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		)}

		{/* Excerpts */}
		{display.enableExcerpts && (item.excerpt || item.content) && (
			<div class="rss-item-excerpt">
				<p>
					{item.excerpt || item.content}
					{display.enableReadMore && (
						<a href={item.url} target={linkTarget} rel={linkRel} class="rss-read-more">
							{display.readMoreText || "Read more"}
						</a>
					)}
				</p>
			</div>
		)}

		{/* Audio Player */}
		{display.enableAudioPlayer && item.audioUrl && (
			<div class={`rss-audio-player position-${display.audioPlayerPosition}`}>
				<audio controls src={item.audioUrl} preload="none"></audio>
			</div>
		)}
	</div>
</div>

<style>
	.rss-item {
		display: flex;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		border-radius: 12px;
		background: var(--rss-item-bg, #ffffff);
		border: 1px solid var(--rss-item-border, #eef0f3);
		overflow: hidden;
		box-sizing: border-box;
	}

	.rss-item:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
		border-color: var(--rss-item-border-hover, #d9e0e8);
	}

	/* List layout details */
	.list-item {
		flex-direction: row;
		padding: 16px;
		gap: 20px;
		align-items: center;
	}

	/* Excerpts layout details */
	.excerpts-item {
		flex-direction: column;
		padding: 20px;
		gap: 16px;
	}
	.excerpts-item .rss-media-wrapper img {
		width: 100%;
		height: auto;
		max-height: 300px;
		object-fit: cover;
		border-radius: 8px;
	}

	/* Thumbnail layout details */
	.thumbnails-item {
		flex-direction: row;
		padding: 12px;
		gap: 16px;
		align-items: flex-start;
	}
	.thumbnails-item .rss-media-wrapper img {
		border-radius: 6px;
	}

	/* Grid layout details */
	.grid-item {
		flex-direction: column;
		height: 100%;
		border-radius: 14px;
	}
	.grid-item .rss-media-wrapper img {
		width: 100%;
		height: 200px;
	}
	.grid-item .rss-content-wrapper {
		padding: 20px;
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: 10px;
	}

	/* Background Image Grid Card */
	.bg-image-card {
		color: #ffffff;
		position: relative;
		min-height: 280px;
		background-size: cover;
		background-position: center;
		justify-content: flex-end;
		padding: 0;
	}
	.bg-image-card .rss-content-wrapper {
		background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.85) 50%, rgba(0,0,0,0.95) 100%);
		padding: 24px 20px 20px;
		width: 100%;
		box-sizing: border-box;
	}
	.bg-image-card .rss-item-title a,
	.bg-image-card .rss-item-title span {
		color: #ffffff !important;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
	}
	.bg-image-card .rss-item-meta {
		color: rgba(255, 255, 255, 0.7) !important;
	}
	.bg-image-card .rss-item-meta a {
		color: rgba(255, 255, 255, 0.9) !important;
	}

	/* Elements */
	.rss-media-wrapper {
		display: flex;
		flex-shrink: 0;
		overflow: hidden;
		border-radius: 8px;
	}
	.rss-image-link {
		display: block;
		width: 100%;
		height: 100%;
	}
	.rss-media-wrapper img {
		display: block;
		transition: transform 0.5s ease;
	}
	.rss-item:hover .rss-media-wrapper img {
		transform: scale(1.03);
	}

	.rss-content-wrapper {
		width: 100%;
	}

	.rss-item-title {
		margin: 0 0 6px 0;
		font-size: 1.15rem;
		line-height: 1.4;
		font-weight: 700;
	}
	.rss-item-title a {
		color: var(--rss-title-color, #1f2937);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.rss-item-title a:hover {
		color: var(--rss-primary-color, #2563eb);
	}

	.rss-item-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		font-size: 0.8rem;
		color: var(--rss-meta-color, #6b7280);
		margin-bottom: 8px;
	}
	.rss-item-meta a {
		color: inherit;
		text-decoration: none;
	}
	.rss-item-meta a:hover {
		text-decoration: underline;
	}
	.rss-meta-source::after,
	.rss-meta-date::after {
		content: "•";
		margin-left: 12px;
		color: var(--rss-meta-separator, #d1d5db);
	}

	.rss-video-embed {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		overflow: hidden;
		border-radius: 8px;
		margin: 10px 0;
	}
	.rss-video-embed iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	.rss-item-excerpt {
		font-size: 0.925rem;
		line-height: 1.6;
		color: var(--rss-excerpt-color, #4b5563);
		margin-top: 8px;
	}
	.rss-item-excerpt p {
		margin: 0;
	}
	.rss-read-more {
		margin-left: 6px;
		color: var(--rss-primary-color, #2563eb);
		text-decoration: none;
		font-weight: 600;
	}
	.rss-read-more:hover {
		text-decoration: underline;
	}

	.rss-audio-player {
		margin-top: 12px;
		width: 100%;
	}
	.rss-audio-player audio {
		width: 100%;
		height: 36px;
	}
</style>
