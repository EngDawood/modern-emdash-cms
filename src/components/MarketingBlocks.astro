---
import type { PortableTextBlock } from "emdash";
import { PortableText } from "emdash/ui";

interface Props {
	value: PortableTextBlock[];
}

const { value } = Astro.props;

// Dynamic imports avoid the Vite dep-scan error: esbuild doesn't enforce default
// export existence on import() expressions, unlike static `import X from Y`.
const [Hero, Features, Testimonials, Pricing, FAQ] = await Promise.all([
	import("./blocks/Hero.astro").then((m) => m.default),
	import("./blocks/Features.astro").then((m) => m.default),
	import("./blocks/Testimonials.astro").then((m) => m.default),
	import("./blocks/Pricing.astro").then((m) => m.default),
	import("./blocks/FAQ.astro").then((m) => m.default),
]);

const marketingTypes = {
	"marketing.hero": Hero,
	"marketing.features": Features,
	"marketing.testimonials": Testimonials,
	"marketing.pricing": Pricing,
	"marketing.faq": FAQ,
};
---

<PortableText value={value} components={{ type: marketingTypes }} />
