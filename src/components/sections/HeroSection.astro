---
import { t, type Locale } from "../../i18n/utils";

interface Props {
	locale: Locale;
	email: string;
}

const { locale, email } = Astro.props;
---

<section id="hero" class="hero">
	<div class="hero-inner">
		<div class="masthead-bar">
			<span class="masthead-vol">Vol. V · {new Date().getFullYear()}</span>
			<span class="masthead-sep">◆</span>
			<span class="masthead-loc">{t("hero.location", locale)}</span>
			<span class="masthead-sep">◆</span>
			<span class="masthead-avail">
				<span class="avail-dot"></span>
				{t("hero.available", locale)}
			</span>
		</div>

		<div class="bilingual-lockup" dir="ltr">
			<div class="lockup-latin">
				<span class="lockup-lang">Lat. · 01</span>
				<span class="lockup-first">Dawood</span>
				<em class="lockup-last">Saleh.</em>
			</div>
			<div class="lockup-pivot">
				<span class="pivot-line"></span>
				<span class="pivot-diamond">◆</span>
				<span class="pivot-line"></span>
			</div>
			<div class="lockup-arabic" dir="rtl">
				<span class="lockup-lang" dir="ltr">Ar. · 02</span>
				<span class="lockup-first-ar">داوود</span>
				<span class="lockup-last-ar">صالح.</span>
			</div>
		</div>

		<hr class="masthead-rule" />

		<div class="hero-body">
			<div class="hero-lede">
				<p class="hero-role">{t("hero.role", locale)} —</p>
				<p class="hero-lede-text">{t("hero.subtitle", locale)}</p>
				<div class="hero-cta-row">
					<a href={`mailto:${email}`} class="btn btn-primary">{t("hero.cta", locale)}</a>
					<a href="#work" class="btn btn-ghost">{t("hero.viewProjects", locale)}</a>
				</div>
			</div>
			<aside class="hero-side">
				<div class="stack-label">— {locale === "ar" ? "الأدوات" : "Stack"} —</div>
				<div class="hero-stack-list">
					{t("hero.stack", locale).split(" · ").map((s: string) => (
						<div class="stack-item">
							<span class="stack-bullet">✦</span>
							<span>{s}</span>
						</div>
					))}
				</div>
				<div class="hero-metrics">
					<div class="metric"><b>4M+</b><span>{t("hero.metrics.records", locale)}</span></div>
					<div class="metric"><b>9+</b><span>{t("hero.metrics.platforms", locale)}</span></div>
					<div class="metric"><b>5y</b><span>{t("hero.metrics.years", locale)}</span></div>
				</div>
			</aside>
		</div>
	</div>
	<div class="hero-ticker">
		<div class:list={["ticker-track", { "ticker-rtl": locale === "ar" }]}>
			{[0, 1, 2].map(() => (
				<span class="ticker-item">
					MCP SERVER LIVE · ARABIC RESEARCH · 4,127,301 RECORDS INDEXED · NODE.JS · TYPESCRIPT · CLOUDFLARE WORKERS · HONO · OPEN TO WORK ·&nbsp;
				</span>
			))}
		</div>
	</div>
</section>

<style>
	/* ── Hero ── */
	.hero {
		border-bottom: 1px solid var(--color-border);
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-12);
	}

	.masthead-bar {
		display: flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-10);
	}

	.masthead-sep {
		color: var(--color-accent);
		font-size: 8px;
	}

	.masthead-avail {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.avail-dot {
		width: 6px;
		height: 6px;
		background: #22c55e;
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* Bilingual Lockup */
	.bilingual-lockup {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(32px, 5vw, 72px);
		margin-bottom: var(--spacing-8);
	}

	.lockup-latin,
	.lockup-arabic {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.lockup-latin {
		align-items: flex-end;
	}

	.lockup-arabic {
		align-items: flex-start;
	}

	.lockup-lang {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.lockup-first {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(36px, 6vw, 72px);
		font-weight: 500;
		color: var(--color-text);
		line-height: 0.95;
		letter-spacing: -0.03em;
	}

	.lockup-last {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(36px, 6vw, 72px);
		font-weight: 400;
		font-style: italic;
		color: var(--color-accent);
		line-height: 0.95;
		letter-spacing: -0.02em;
	}

	.lockup-first-ar {
		font-family: "Amiri", "Al Jazeera", serif;
		font-size: clamp(40px, 6.5vw, 80px);
		font-weight: 700;
		color: var(--color-text);
		line-height: 0.95;
	}

	.lockup-last-ar {
		font-family: "Amiri", "Al Jazeera", serif;
		font-size: clamp(40px, 6.5vw, 80px);
		font-weight: 400;
		color: var(--color-accent);
		line-height: 0.95;
	}

	.lockup-pivot {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		flex-shrink: 0;
	}

	.pivot-line {
		display: block;
		width: 1px;
		height: clamp(40px, 5vw, 64px);
		background: var(--color-text);
		opacity: 0.18;
	}

	.pivot-diamond {
		color: var(--color-accent);
		font-size: 18px;
		line-height: 1;
	}

	.masthead-rule {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: var(--spacing-8) 0;
	}

	/* Hero body */
	.hero-body {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: var(--spacing-12);
		align-items: start;
	}

	.hero-role {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-3);
	}

	.hero-lede-text {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: 1.6;
		max-width: 480px;
		margin-bottom: var(--spacing-8);
	}

	.hero-cta-row {
		display: flex;
		gap: var(--spacing-4);
		flex-wrap: wrap;
	}

	.hero-side {
		min-width: 180px;
		border-left: 1px solid var(--color-border);
		padding-left: var(--spacing-8);
	}

	html[dir="rtl"] .hero-side {
		border-left: none;
		border-right: 1px solid var(--color-border);
		padding-left: 0;
		padding-right: var(--spacing-8);
	}

	.stack-label {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.2em;
		color: var(--color-muted);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
		text-align: center;
	}

	.hero-stack-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-6);
	}

	.stack-item {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.stack-bullet {
		color: var(--color-accent);
		font-size: 8px;
	}

	.hero-metrics {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-4);
	}

	.metric {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.metric b {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		color: var(--color-text);
		line-height: 1;
	}

	.metric span {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	/* Ticker */
	.hero-ticker {
		background: var(--color-accent);
		overflow: hidden;
		padding: 10px 0;
	}

	.ticker-track {
		display: flex;
		white-space: nowrap;
		animation: ticker 28s linear infinite;
	}

	.ticker-rtl {
		animation-direction: reverse;
	}

	@media (prefers-reduced-motion: reduce) {
		.ticker-track { animation: none; }
	}

	@keyframes ticker {
		from { transform: translateX(0); }
		to { transform: translateX(-33.333%); }
	}

	.ticker-item {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-on-accent);
		opacity: 0.9;
		padding-right: var(--spacing-8);
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.bilingual-lockup {
			gap: 20px;
		}

		.lockup-first,
		.lockup-last {
			font-size: clamp(28px, 7vw, 48px);
		}

		.lockup-first-ar,
		.lockup-last-ar {
			font-size: clamp(32px, 7.5vw, 52px);
		}

		.hero-body {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.hero-side {
			border-left: none;
			border-top: 1px solid var(--color-border);
			padding-left: 0;
			padding-top: var(--spacing-6);
			display: flex;
			gap: var(--spacing-8);
			align-items: flex-start;
		}

		html[dir="rtl"] .hero-side {
			border-right: none;
			padding-right: 0;
		}

		.hero-metrics {
			flex-direction: row;
			flex-wrap: wrap;
			gap: var(--spacing-5);
			border-top: none;
			padding-top: 0;
		}
	}

	@media (max-width: 480px) {
		.bilingual-lockup {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: var(--spacing-4);
		}

		.lockup-latin { align-items: center; }
		.lockup-arabic { align-items: center; }

		.lockup-pivot {
			flex-direction: row;
			height: auto;
			width: 100%;
			justify-content: center;
		}

		.pivot-line {
			width: clamp(32px, 10vw, 60px);
			height: 1px;
		}

		.masthead-bar {
			flex-wrap: wrap;
			gap: 8px;
		}
	}
</style>
