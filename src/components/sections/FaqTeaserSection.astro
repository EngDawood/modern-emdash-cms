---
import { t, type Locale } from "../../i18n/utils";

interface Props {
	faqItems: { question: string; answer: string }[];
	locale: Locale;
}

const { faqItems, locale } = Astro.props;
---

{faqItems.length > 0 && (
	<section id="faq" class="section-faq reveal">
		<div class="section-inner">
			<div class="section-head reveal-child">
				<div class="kicker">
					<span class="kicker-num">§05</span>
					<span class="kicker-rule"></span>
					{t("faq.kicker", locale)}
				</div>
				<h2 class="section-title">{t("faq.heading", locale)}</h2>
				<p class="section-sub">{t("faq.subheading", locale)}</p>
			</div>
			<div class="faq-teaser-list">
				{faqItems.slice(0, 4).map((item, i) => (
					<details class="faq-teaser-item reveal-item" style={`--delay: ${i}`}>
						<summary class="faq-teaser-question">{item.question}</summary>
						<p class="faq-teaser-answer">{item.answer}</p>
					</details>
				))}
			</div>
			<a href={`/${locale}/faq`} class="view-all reveal-child">{t("faq.viewAll", locale)} →</a>
		</div>
	</section>
)}

<style>
	/* ── FAQ teaser ── */
	.faq-teaser-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.faq-teaser-item {
		border-bottom: 1px solid var(--color-border);
		padding: var(--spacing-4) 0;
	}

	.faq-teaser-question {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 500;
		color: var(--color-text);
		cursor: pointer;
		list-style: none;
	}

	.faq-teaser-question::-webkit-details-marker {
		display: none;
	}

	.faq-teaser-answer {
		margin-top: var(--spacing-3);
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-muted);
		line-height: 1.6;
	}
</style>
