---
import { t, type Locale } from "../../i18n/utils";
import { skillsData } from "../../data/skills";

interface Props {
	locale: Locale;
	email: string;
}

const { locale, email } = Astro.props;
---

<section id="about" class="section-about reveal">
	<div class="section-inner">
		<div class="section-head reveal-child">
			<div class="kicker">
				<span class="kicker-num">§03</span>
				<span class="kicker-rule"></span>
				{t("about.kicker", locale)}
			</div>
		</div>
		<div class="about-grid reveal-child">
			<div class="about-info">
				<h3 class="about-heading">
					{t("about.heading1", locale)}
					<br /><span class="accent">{t("about.heading2", locale)}</span>
				</h3>
				<dl class="info-list">
					<div class="info-row">
						<dt>{t("about.info.location", locale)}</dt>
						<dd>{t("about.info.locationVal", locale)}</dd>
					</div>
					<div class="info-row">
						<dt>{t("about.info.focus", locale)}</dt>
						<dd>{t("about.info.focusVal", locale)}</dd>
					</div>
					<div class="info-row">
						<dt>{t("about.info.email", locale)}</dt>
						<dd><a href={`mailto:${email}`}>{email}</a></dd>
					</div>
					<div class="info-row">
						<dt>{t("about.info.status", locale)}</dt>
						<dd class="status-available">{t("about.info.statusVal", locale)}</dd>
					</div>
				</dl>
			</div>
			<div class="about-bio">
				<p class="bio-dropcap">{t("about.bio1", locale)}</p>
				<p>{t("about.bio2", locale)}</p>
				<p>{t("about.bio3", locale)}</p>
			</div>
		</div>
		<div class="skills-grid">
			{Object.entries(skillsData).map(([key, category], index) => (
				<div class="skill-group reveal-item" style={`--delay: ${index}`}>
					<h4 class="skill-group-title">{t(`skills.categories.${key}`, locale)}</h4>
					<div class="skill-badges">
						{category.skills.map((skill) => (
							<span class:list={[
								"skill-badge",
								skill.level >= 90 ? "badge-filled" : skill.level >= 80 ? "badge-secondary" : "badge-outline"
							]}>
								{skill.name}
							</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	/* ── About §03 ── */
	.section-about {
		border-bottom: 1px solid var(--color-border);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1.6fr;
		gap: var(--spacing-16);
		margin-bottom: var(--spacing-16);
	}

	.about-heading {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-8);
	}

	.info-list {
		display: flex;
		flex-direction: column;
	}

	.info-row {
		display: flex;
		justify-content: space-between;
		padding: var(--spacing-3) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.info-row dt {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.info-row dd {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
		text-align: end;
	}

	.info-row dd a {
		text-decoration: none;
		color: var(--color-text);
	}

	.info-row dd a:hover {
		color: var(--color-accent);
	}

	.status-available {
		color: #22c55e;
	}

	.about-bio p {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: 1.75;
		margin-bottom: var(--spacing-5);
	}

	.bio-dropcap::first-letter {
		font-family: "Playfair Display", Georgia, serif;
		font-size: 3.4em;
		font-weight: 700;
		float: left;
		line-height: 0.78;
		margin-right: 6px;
		margin-top: 4px;
		color: var(--color-accent);
	}

	html[dir="rtl"] .bio-dropcap::first-letter {
		float: right;
		margin-right: 0;
		margin-left: 6px;
	}

	/* Skills grid */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}

	.skill-group {
		padding: var(--spacing-5);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}

	.skill-group-title {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.skill-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.skill-badge {
		padding: 3px 10px;
		font-size: var(--font-size-xs);
		font-family: var(--font-mono);
		letter-spacing: 0.05em;
		border-radius: 2px;
		transition: border-color var(--transition-fast), color var(--transition-fast);
	}

	.badge-filled {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.badge-secondary {
		background: var(--color-bg-subtle);
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.badge-outline {
		background: transparent;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
	}

	.skill-badge:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.skills-grid {
			grid-template-columns: 1fr 1fr;
		}

		.info-row {
			flex-direction: column;
			gap: 0.25rem;
		}
	}

	@media (max-width: 480px) {
		.skills-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
