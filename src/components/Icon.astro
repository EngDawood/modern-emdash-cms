---
interface Props {
	name: string;
	class?: string;
	[key: string]: any;
}

const { name, class: className, ...rest } = Astro.props;

const icons: Record<string, { paths: string; viewBox?: string; fill?: string; stroke?: string; strokeWidth?: string }> = {
