---
import { getOtherLocale, stripLocale, type Locale } from "../i18n/utils";

interface Props {
	locale: Locale;
	class?: string;
}

const { locale, class: className } = Astro.props;
const otherLocale = getOtherLocale(locale);
const currentPath = stripLocale(Astro.url.pathname);
const switchUrl = `/${otherLocale}${currentPath === "/" ? "" : currentPath}`;
const label = locale === "ar" ? "EN" : "عربي";
---

<a href={switchUrl} class:list={["lang-switch", className]} aria-label={`Switch to ${otherLocale === "ar" ? "Arabic" : "English"}`}>
	{label}
</a>

<style>
	.lang-switch {
		display: inline-flex;
		align-items: center;
		padding: 0.375rem 0.75rem;
		font-size: var(--font-size-sm, 0.875rem);
		font-weight: 500;
		color: var(--color-text);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius, 0.375rem);
		text-decoration: none;
		transition: all 0.15s ease;
	}

	.lang-switch:hover {
		background: var(--color-accent);
		color: var(--color-bg);
		border-color: var(--color-accent);
	}
</style>
