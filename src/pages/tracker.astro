---
import TrackerApp from "../components/tracker/TrackerApp";

// Auth guard — only EmDash-authenticated users can access this page
if (!Astro.locals.user) {
	return Astro.redirect("/_emdash/admin", 302);
}
---

<!doctype html>
<html lang="en" dir="ltr">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<title>Tracker — Freelance Workspace</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap"
		/>
	</head>
	<body>
		<TrackerApp client:only="react" />
	</body>
</html>
