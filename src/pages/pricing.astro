---
export const prerender = false;

import { getEmDashEntry } from "emdash";
import Base from "../layouts/Base.astro";
import MarketingBlocks from "../components/MarketingBlocks.astro";
import { defaultLocale, t } from "../i18n/utils";
import type { Locale } from "../i18n/utils";

const locale: Locale = defaultLocale;
const { entry: page, cacheHint } = await getEmDashEntry("pages", "pricing", { locale });

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const pageContent = page?.data.content;
---

<Base
	title={page?.data.title || t("nav.pricing", locale) || "الأسعار"}
	description={page?.data.description || "أسعار بسيطة وشفافة."}
	locale={locale}
>
	{
		pageContent ? (
			<MarketingBlocks value={pageContent} />
		) : (
			<div class="empty-state">
				<h1>الأسعار</h1>
				<p>أضف محتوى الأسعار في لوحة التحكم.</p>
				<a href="/_emdash/admin" class="btn btn-primary">فتح لوحة التحكم</a>
			</div>
		)
	}
</Base>

<style>
	.empty-state {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.empty-state h1 {
		margin-bottom: var(--spacing-md);
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: var(--spacing-xl);
	}
</style>
