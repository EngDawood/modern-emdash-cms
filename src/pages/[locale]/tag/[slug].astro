---
import { getTerm, getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../../layouts/Base.astro";
import PostCard from "../../../components/PostCard.astro";
import { getReadingTime } from "../../../utils/reading-time";
import { t, locales, type Locale, defaultLocale } from "../../../i18n/utils";

// Validate locale
const { locale: localeParam, slug } = Astro.params;
const locale: Locale = locales.includes(localeParam as Locale)
	? (localeParam as Locale)
	: defaultLocale;

const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.redirect(`/${locale}/404`);
}

const { entries: posts } = await getEmDashCollection("posts", {
	locale,
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
});

const tagsMap = await getTermsForEntries("posts", posts.map(p => p.data.id), "tag");
const filteredPosts = posts.map(post => ({ post, tags: tagsMap.get(post.data.id) ?? [] }));
---

<Base
	title={`${t("archive.postsTitle", locale)} "${term.label}"`}
	description={`${t("archive.postsDesc", locale)} ${term.label}`}
	locale={locale}
>
	<section class="archive-section">
		<header class="archive-header">
			<span class="archive-label">{t("archive.tag", locale)}</span>
			<h1 class="archive-title">{term.label}</h1>
			<p class="archive-count">
				{filteredPosts.length}
				{filteredPosts.length === 1 ? t("archive.postSingular", locale) : t("archive.postPlural", locale)}
			</p>
		</header>

		{
			filteredPosts.length === 0 ? (
				<p class="no-posts">{t("archive.noPostsTag", locale)}</p>
			) : (
				<div class="posts-grid">
					{filteredPosts.map(({ post, tags }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/${locale}/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
							locale={locale}
						/>
					))}
				</div>
			)
		}
	</section>
</Base>

<style>
	.archive-section {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6);
	}

	.archive-header {
		margin-bottom: var(--spacing-12);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.archive-label {
		display: block;
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		margin-bottom: var(--spacing-2);
	}

	.archive-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-4xl);
		font-weight: 500;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-2);
	}

	.archive-count {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.no-posts {
		color: var(--color-muted);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
