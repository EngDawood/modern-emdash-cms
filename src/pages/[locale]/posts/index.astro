---
import { getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../../layouts/Base.astro";
import { getReadingTime } from "../../../utils/reading-time";
import { t, locales, type Locale, defaultLocale } from "../../../i18n/utils";

// Validate locale
const { locale: localeParam } = Astro.params;
const locale: Locale = locales.includes(localeParam as Locale)
	? (localeParam as Locale)
	: defaultLocale;

if (!locales.includes(localeParam as Locale)) {
	return Astro.redirect(`/${defaultLocale}/posts`, 302);
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts");

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const postTagsMap = await getTermsForEntries("posts", sortedPosts.map(p => p.data.id), "tag");
const postsWithTags = sortedPosts.map(post => ({
	post,
	tags: postTagsMap.get(post.data.id) ?? [],
	bylines: post.data.bylines ?? [],
}));

const formatDate = (date: Date) =>
	date.toLocaleDateString(locale === "ar" ? "ar-SA" : "en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
---

<Base title={t("nav.blog", locale)} description={locale === "ar" ? "مقالات عن البرمجة والذكاء الاصطناعي" : "Writing on development, AI, and building"} locale={locale}>
	<div class="posts-page">
		<header class="page-header">
			<div class="page-header-text">
				<h1 class="page-title">{t("nav.blog", locale)}</h1>
				<p class="page-description">
					{posts.length}
					{locale === "ar"
						? (posts.length === 1 ? "مقال" : "مقالات")
						: (posts.length === 1 ? "article" : "articles")}
				</p>
			</div>
			<a href="/rss/posts.xml" class="rss-link" title={t("footer.rss", locale)} aria-label={t("footer.rss", locale)}>
				<svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
					<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
				</svg>
			</a>
		</header>

		{
			sortedPosts.length === 0 ? (
				<p class="empty">{locale === "ar" ? "لا توجد مقالات بعد." : "No posts yet."}</p>
			) : (
				<div class="posts-list">
					{postsWithTags.map(({ post, tags, bylines }) => (
						<article class="post-item">
							<a href={`/${locale}/posts/${post.id}`} class="post-link">
								<div class="post-meta">
									{bylines.length > 0 && (
										<>
											<div class="post-bylines">
												{bylines.slice(0, 2).map((credit, index) => (
													<>
														{index > 0 && <span class="byline-sep">,</span>}
														<span class="post-byline">
															{credit.byline.avatarMediaId && (
																<img
																	src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
																	alt={credit.byline.displayName}
																	class="post-byline-avatar"
																/>
															)}
															<span class="post-byline-name">
																{credit.byline.displayName}
															</span>
														</span>
													</>
												))}
												{bylines.length > 2 && (
													<span class="byline-more">+{bylines.length - 2}</span>
												)}
											</div>
											<span class="meta-dot" />
										</>
									)}
									{post.data.publishedAt && (
										<time>{formatDate(post.data.publishedAt)}</time>
									)}
									{post.data.publishedAt && <span class="meta-dot" />}
									<span>{getReadingTime(post.data.content)} {locale === "ar" ? "دقيقة قراءة" : "min read"}</span>
								</div>
								<h2 class="post-title">{post.data.title}</h2>
								{post.data.excerpt && (
									<p class="post-excerpt">{post.data.excerpt}</p>
								)}
							</a>
							{tags.length > 0 && (
								<div class="post-tags">
									{tags.slice(0, 3).map((t) => (
										<a href={`/${locale}/tag/${t.slug}`} class="post-tag">
											{t.label}
										</a>
									))}
								</div>
							)}
						</article>
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.posts-page {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-12);
	}

	.page-header-text {
		flex: 1;
	}

	.rss-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		color: var(--color-muted);
		transition: color var(--transition-fast);
		flex-shrink: 0;
		margin-top: 0.35rem;
	}

	.rss-link:hover {
		color: var(--color-accent);
	}

	.rss-link svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.page-title {
		font-size: var(--font-size-4xl);
		font-weight: 500;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		font-family: var(--font-serif);
		font-style: italic;
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	.post-item {
		padding: var(--spacing-8) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.post-item:first-child {
		padding-top: 0;
	}

	.post-item:last-child {
		border-bottom: none;
	}

	.post-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2);
	}

	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}

	.post-bylines {
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.post-byline {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
	}

	.post-byline-avatar {
		width: var(--avatar-size-sm);
		height: var(--avatar-size-sm);
		border-radius: 50%;
		object-fit: cover;
	}

	.post-byline-name {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.byline-sep {
		color: var(--color-muted);
		margin-right: 2px;
	}

	.byline-more {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		margin-left: 2px;
	}

	.post-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		line-height: var(--leading-snug);
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-2);
		transition: color var(--transition-fast);
	}

	.post-link:hover .post-title {
		color: var(--color-accent);
	}

	.post-excerpt {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-4);
	}

	.post-tag {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
		text-decoration: none;
		transition: color var(--transition-fast), background var(--transition-fast);
	}

	.post-tag:hover {
		color: var(--color-text);
		background: var(--color-border);
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.post-title {
			font-size: var(--font-size-xl);
		}
	}
</style>
