---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../../layouts/Base.astro";
import { t, locales, type Locale, defaultLocale } from "../../i18n/utils";
import { skillsData } from "../../data/skills";

// In server mode, validate locale from params
const { locale: localeParam } = Astro.params;
const locale: Locale = locales.includes(localeParam as Locale)
	? (localeParam as Locale)
	: defaultLocale;

// Redirect if invalid locale
if (!locales.includes(localeParam as Locale)) {
	return Astro.redirect(`/${defaultLocale}/`, 302);
}

const [settings, { entries: projects, cacheHint }, { entries: posts }] = await Promise.all([
	getSiteSettings(),
	getEmDashCollection("projects"),
	getEmDashCollection("posts"),
]);
Astro.cache.set(cacheHint);

// Get the 3 most recent projects for the homepage
const featuredProjects = projects
	.toSorted((a, b) => {
		const dateA = a.data.publishedAt?.getTime() ?? 0;
		const dateB = b.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);

// Get 4 most recent posts for the writing section
const recentPosts = posts
	.toSorted((a, b) => {
		const dateA = a.data.publishedAt?.getTime() ?? 0;
		const dateB = b.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

const email = "eng.dawoodsaleh@gmail.com";
const telegram = "https://t.me/Daw5d";
const github = settings.social?.github ?? "https://github.com/EngDawood";
const linkedin = settings.social?.linkedin ?? "https://www.linkedin.com/in/dawood3";
const twitter = settings.social?.twitter ?? "https://x.com/dawo5d";

// Contact form state
let formStatus: "idle" | "success" | "error" = "idle";
let formMessage = "";

if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const name = formData.get("name")?.toString() || "";
		const emailVal = formData.get("email")?.toString() || "";
		const message = formData.get("message")?.toString() || "";

		if (!name || !emailVal || !message) {
			formStatus = "error";
			formMessage = t("contact.form.error", locale);
		} else if (!emailVal.includes("@")) {
			formStatus = "error";
			formMessage = t("contact.form.error", locale);
		} else {
			const res = await fetch(new URL("/_emdash/api/plugins/emdash-forms/submit", Astro.url), {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					formId: "contact",
					data: { name, email: emailVal, message },
				}),
			});
			const result = await res.json() as { success: boolean; message?: string };
			if (!result.success) throw new Error(result.message || "Submission failed");
			formStatus = "success";
			formMessage = result.message || t("contact.form.success", locale);
		}
	} catch {
		formStatus = "error";
		formMessage = t("contact.form.error", locale);
	}
}
---

<Base
	title={t("meta.title", locale)}
	description={t("meta.description", locale)}
	locale={locale}
>
	<!-- ── HERO ── -->
	<section id="hero" class="hero">
		<div class="hero-inner">
			<div class="masthead-bar">
				<span class="masthead-vol">Vol. V · {new Date().getFullYear()}</span>
				<span class="masthead-sep">◆</span>
				<span class="masthead-loc">{t("hero.location", locale)}</span>
				<span class="masthead-sep">◆</span>
				<span class="masthead-avail">
					<span class="avail-dot"></span>
					{t("hero.available", locale)}
				</span>
			</div>

			<div class="bilingual-lockup" dir="ltr">
				<div class="lockup-latin">
					<span class="lockup-lang">Lat. · 01</span>
					<span class="lockup-first">Dawood</span>
					<em class="lockup-last">Saleh.</em>
				</div>
				<div class="lockup-pivot">
					<span class="pivot-line"></span>
					<span class="pivot-diamond">◆</span>
					<span class="pivot-line"></span>
				</div>
				<div class="lockup-arabic" dir="rtl">
					<span class="lockup-lang" dir="ltr">Ar. · 02</span>
					<span class="lockup-first-ar">داوود</span>
					<span class="lockup-last-ar">صالح.</span>
				</div>
			</div>

			<hr class="masthead-rule" />

			<div class="hero-body">
				<div class="hero-lede">
					<p class="hero-role">{t("hero.role", locale)} —</p>
					<p class="hero-lede-text">{t("hero.subtitle", locale)}</p>
					<div class="hero-cta-row">
						<a href={`mailto:${email}`} class="btn btn-primary">{t("hero.cta", locale)}</a>
						<a href="#work" class="btn btn-ghost">{t("hero.viewProjects", locale)}</a>
					</div>
				</div>
				<aside class="hero-side">
					<div class="stack-label">— {locale === "ar" ? "الأدوات" : "Stack"} —</div>
					<div class="hero-stack-list">
						{t("hero.stack", locale).split(" · ").map((s: string) => (
							<div class="stack-item">
								<span class="stack-bullet">✦</span>
								<span>{s}</span>
							</div>
						))}
					</div>
					<div class="hero-metrics">
						<div class="metric"><b>4M+</b><span>{t("hero.metrics.records", locale)}</span></div>
						<div class="metric"><b>9+</b><span>{t("hero.metrics.platforms", locale)}</span></div>
						<div class="metric"><b>5y</b><span>{t("hero.metrics.years", locale)}</span></div>
					</div>
				</aside>
			</div>
		</div>
		<div class="hero-ticker">
			<div class:list={["ticker-track", { "ticker-rtl": locale === "ar" }]}>
				{[0, 1, 2].map((k) => (
					<span class="ticker-item">
						MCP SERVER LIVE · ARABIC RESEARCH · 4,127,301 RECORDS INDEXED · NODE.JS · TYPESCRIPT · CLOUDFLARE WORKERS · HONO · OPEN TO WORK ·&nbsp;
					</span>
				))}
			</div>
		</div>
	</section>

	<!-- ── WORK §01 ── -->
	<section id="work" class="section-work reveal">
		<div class="section-inner">
			<div class="section-head reveal-child">
				<div class="kicker">
					<span class="kicker-num">§01</span>
					<span class="kicker-rule"></span>
					{t("projects.kicker", locale)}
				</div>
				<h2 class="section-title">{t("projects.heading", locale)}</h2>
			</div>
			<div class="project-rows">
				{featuredProjects.map((project, i) => (
					<a href={`/${locale}/work/${project.id}`} class="project-row reveal-item" style={`--delay: ${i}`}>
						<div class="row-meta">
							<span class="row-num">0{i + 1}</span>
							<span class="row-year">{project.data.year}</span>
						</div>
						<h3 class="row-title">{project.data.title}</h3>
						<p class="row-desc">{project.data.summary}</p>
						<div class="row-footer">
							<span class="row-arrow">→</span>
						</div>
					</a>
				))}
			</div>
			<a href={`/${locale}/work`} class="view-all reveal-child">{t("projects.viewAll", locale)} →</a>
		</div>
	</section>

	<!-- ── WRITING §02 ── -->
	<section id="writing" class="section-writing reveal">
		<div class="section-inner">
			<div class="section-head reveal-child">
				<div class="kicker">
					<span class="kicker-num">§02</span>
					<span class="kicker-rule"></span>
					{t("writing.kicker", locale)}
				</div>
				<h2 class="section-title">{t("writing.heading", locale)}</h2>
				<p class="section-sub">{t("writing.subheading", locale)}</p>
			</div>
			{recentPosts.length > 0 && (
				<div class="writing-grid">
					<a href={`/${locale}/posts/${recentPosts[0].id}`} class="writing-card feature-card reveal-item" style="--delay: 0">
						<div class="writing-meta">
							{recentPosts[0].data.publishedAt && (
								<span class="writing-date">{recentPosts[0].data.publishedAt.toLocaleDateString(locale === "ar" ? "ar-SA" : "en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
							)}
						</div>
						<h3 class="writing-title">{recentPosts[0].data.title}</h3>
						<span class="writing-cta">{locale === "ar" ? "اقرأ المقال ←" : "Read the piece →"}</span>
					</a>
					<div class="writing-side">
						{recentPosts.slice(1).map((post, i) => (
							<a href={`/${locale}/posts/${post.id}`} class="writing-card side-card reveal-item" style={`--delay: ${i + 1}`}>
								<div class="writing-meta">
									{post.data.publishedAt && (
										<span class="writing-date">{post.data.publishedAt.toLocaleDateString(locale === "ar" ? "ar-SA" : "en-US", { month: "short", year: "numeric" })}</span>
									)}
								</div>
								<h4 class="writing-title-sm">{post.data.title}</h4>
								<span class="writing-arrow">{locale === "ar" ? "←" : "→"}</span>
							</a>
						))}
					</div>
				</div>
			)}
			<a href={`/${locale}/posts`} class="view-all reveal-child">{t("writing.viewAll", locale)} →</a>
		</div>
	</section>

	<!-- ── ABOUT §03 ── -->
	<section id="about" class="section-about reveal">
		<div class="section-inner">
			<div class="section-head reveal-child">
				<div class="kicker">
					<span class="kicker-num">§03</span>
					<span class="kicker-rule"></span>
					{t("about.kicker", locale)}
				</div>
			</div>
			<div class="about-grid reveal-child">
				<div class="about-info">
					<h3 class="about-heading">
						{t("about.heading1", locale)}
						<br /><span class="accent">{t("about.heading2", locale)}</span>
					</h3>
					<dl class="info-list">
						<div class="info-row">
							<dt>{t("about.info.location", locale)}</dt>
							<dd>{t("about.info.locationVal", locale)}</dd>
						</div>
						<div class="info-row">
							<dt>{t("about.info.focus", locale)}</dt>
							<dd>{t("about.info.focusVal", locale)}</dd>
						</div>
						<div class="info-row">
							<dt>{t("about.info.email", locale)}</dt>
							<dd><a href={`mailto:${email}`}>{email}</a></dd>
						</div>
						<div class="info-row">
							<dt>{t("about.info.status", locale)}</dt>
							<dd class="status-available">{t("about.info.statusVal", locale)}</dd>
						</div>
					</dl>
				</div>
				<div class="about-bio">
					<p class="bio-dropcap">{t("about.bio1", locale)}</p>
					<p>{t("about.bio2", locale)}</p>
					<p>{t("about.bio3", locale)}</p>
				</div>
			</div>
			<div class="skills-grid">
				{Object.entries(skillsData).map(([key, category], index) => (
					<div class="skill-group reveal-item" style={`--delay: ${index}`}>
						<h4 class="skill-group-title">{t(`skills.categories.${key}`, locale)}</h4>
						<div class="skill-badges">
							{category.skills.map((skill) => (
								<span class:list={[
									"skill-badge",
									skill.level >= 90 ? "badge-filled" : skill.level >= 80 ? "badge-secondary" : "badge-outline"
								]}>
									{skill.name}
								</span>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ── CONTACT §04 ── -->
	<section id="contact" class="section-contact reveal">
		<div class="section-inner">
			<div class="section-head reveal-child">
				<div class="kicker">
					<span class="kicker-num">§04</span>
					<span class="kicker-rule"></span>
					{locale === "ar" ? "تواصل" : "CONTACT"}
				</div>
			</div>
			<div class="contact-grid">
				<div class="contact-info reveal-child">
					<h2 class="contact-heading">
						{t("contact.heading1", locale)}
						<span class="accent"> {t("contact.heading2", locale)}</span>
					</h2>
					<p class="contact-description">{t("contact.description", locale)}</p>
					<div class="contact-links">
						<a href={`mailto:${email}`} class="contact-link">
							<span class="link-label">{t("contact.links.email", locale)}</span>
							<span class="link-value">{email}</span>
						</a>
						<a href={github} target="_blank" rel="noopener noreferrer" class="contact-link">
							<span class="link-label">{t("contact.links.github", locale)}</span>
							<span class="link-value">EngDawood</span>
						</a>
						<a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact-link">
							<span class="link-label">{t("contact.links.linkedin", locale)}</span>
							<span class="link-value">dawood3</span>
						</a>
						<a href={telegram} target="_blank" rel="noopener noreferrer" class="contact-link">
							<span class="link-label">{t("contact.links.telegram", locale)}</span>
							<span class="link-value">Daw5d</span>
						</a>
						<a href={twitter} target="_blank" rel="noopener noreferrer" class="contact-link">
							<span class="link-label">{t("contact.links.twitter", locale)}</span>
							<span class="link-value">dawo5d</span>
						</a>
					</div>
				</div>
				<div class="contact-form-wrapper reveal-child">
					<h4 class="form-heading">{t("contact.form.heading", locale)}</h4>
					{formStatus === "success" ? (
						<div class="form-success">
							<p>{formMessage}</p>
							<a href={`/${locale}#contact`} class="btn btn-ghost">{t("contact.cta", locale)}</a>
						</div>
					) : (
						<form method="POST" class="contact-form">
							{formStatus === "error" && (
								<div class="form-error">{formMessage}</div>
							)}
							<div class="form-field">
								<label for="name">{t("contact.form.name", locale)}</label>
								<input type="text" id="name" name="name" required autocomplete="name" />
							</div>
							<div class="form-field">
								<label for="email">{t("contact.form.email", locale)}</label>
								<input type="email" id="email" name="email" required autocomplete="email" />
							</div>
							<div class="form-field">
								<label for="message">{t("contact.form.message", locale)}</label>
								<textarea id="message" name="message" rows="5" required></textarea>
							</div>
							<button type="submit" class="btn btn-primary">
								{t("contact.form.submit", locale)}
							</button>
						</form>
					)}
				</div>
			</div>
		</div>
	</section>
</Base>

<style>
	/* ── Shared layout ── */
	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.section-head {
		margin-bottom: var(--spacing-12);
	}

	.kicker {
		display: flex;
		align-items: center;
		gap: 10px;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.kicker-num {
		color: var(--color-accent);
		font-weight: 400;
	}

	.kicker-rule {
		display: inline-block;
		width: 40px;
		height: 1px;
		background: var(--color-border);
		flex-shrink: 0;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, var(--font-size-3xl));
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.section-sub {
		margin-top: var(--spacing-3);
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-base);
		color: var(--color-muted);
	}

	.view-all {
		display: inline-block;
		margin-top: var(--spacing-10);
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-base);
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.view-all:hover {
		color: var(--color-accent);
	}

	.accent {
		color: var(--color-accent);
	}

	/* ── Buttons ── */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.4rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		border-radius: var(--radius);
		text-decoration: none;
		transition: all var(--transition-fast);
		cursor: pointer;
		border: none;
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-on-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
	}

	.btn-ghost {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-ghost:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* ── Hero ── */
	.hero {
		border-bottom: 1px solid var(--color-border);
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-12);
	}

	.masthead-bar {
		display: flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-10);
	}

	.masthead-sep {
		color: var(--color-accent);
		font-size: 8px;
	}

	.masthead-avail {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.avail-dot {
		width: 6px;
		height: 6px;
		background: #22c55e;
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* Bilingual Lockup */
	.bilingual-lockup {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(32px, 5vw, 72px);
		margin-bottom: var(--spacing-8);
	}

	.lockup-latin,
	.lockup-arabic {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.lockup-latin {
		align-items: flex-end;
	}

	.lockup-arabic {
		align-items: flex-start;
	}

	.lockup-lang {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.lockup-first {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(36px, 6vw, 72px);
		font-weight: 500;
		color: var(--color-text);
		line-height: 0.95;
		letter-spacing: -0.03em;
	}

	.lockup-last {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(36px, 6vw, 72px);
		font-weight: 400;
		font-style: italic;
		color: var(--color-accent);
		line-height: 0.95;
		letter-spacing: -0.02em;
	}

	.lockup-first-ar {
		font-family: "Amiri", "Al Jazeera", serif;
		font-size: clamp(40px, 6.5vw, 80px);
		font-weight: 700;
		color: var(--color-text);
		line-height: 0.95;
	}

	.lockup-last-ar {
		font-family: "Amiri", "Al Jazeera", serif;
		font-size: clamp(40px, 6.5vw, 80px);
		font-weight: 400;
		color: var(--color-accent);
		line-height: 0.95;
	}

	.lockup-pivot {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		flex-shrink: 0;
	}

	.pivot-line {
		display: block;
		width: 1px;
		height: clamp(40px, 5vw, 64px);
		background: var(--color-text);
		opacity: 0.18;
	}

	.pivot-diamond {
		color: var(--color-accent);
		font-size: 18px;
		line-height: 1;
	}

	.masthead-rule {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: var(--spacing-8) 0;
	}

	/* Hero body */
	.hero-body {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: var(--spacing-12);
		align-items: start;
	}

	.hero-role {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-3);
	}

	.hero-lede-text {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: 1.6;
		max-width: 480px;
		margin-bottom: var(--spacing-8);
	}

	.hero-cta-row {
		display: flex;
		gap: var(--spacing-4);
		flex-wrap: wrap;
	}

	.hero-side {
		min-width: 180px;
		border-left: 1px solid var(--color-border);
		padding-left: var(--spacing-8);
	}

	html[dir="rtl"] .hero-side {
		border-left: none;
		border-right: 1px solid var(--color-border);
		padding-left: 0;
		padding-right: var(--spacing-8);
	}

	.stack-label {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.2em;
		color: var(--color-muted);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
		text-align: center;
	}

	.hero-stack-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-6);
	}

	.stack-item {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.stack-bullet {
		color: var(--color-accent);
		font-size: 8px;
	}

	.hero-metrics {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-4);
	}

	.metric {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.metric b {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		color: var(--color-text);
		line-height: 1;
	}

	.metric span {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	/* Ticker */
	.hero-ticker {
		background: var(--color-accent);
		overflow: hidden;
		padding: 10px 0;
	}

	.ticker-track {
		display: flex;
		white-space: nowrap;
		animation: ticker 28s linear infinite;
	}

	.ticker-rtl {
		animation-direction: reverse;
	}

	@media (prefers-reduced-motion: reduce) {
		.ticker-track { animation: none; }
	}

	@keyframes ticker {
		from { transform: translateX(0); }
		to { transform: translateX(-33.333%); }
	}

	.ticker-item {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-on-accent);
		opacity: 0.9;
		padding-right: var(--spacing-8);
	}

	/* ── Work §01 ── */
	.section-work {
		border-bottom: 1px solid var(--color-border);
	}

	.project-rows {
		border-top: 1px solid var(--color-border);
	}

	.project-row {
		display: block;
		padding: var(--spacing-8) 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		position: relative;
		transition: padding-left var(--transition-base);
	}

	.project-row::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--color-accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--transition-base);
	}

	html[dir="rtl"] .project-row::before {
		transform-origin: right;
	}

	.project-row:hover::before {
		transform: scaleX(1);
	}

	.project-row:hover {
		padding-left: var(--spacing-4);
	}

	html[dir="rtl"] .project-row:hover {
		padding-left: 0;
		padding-right: var(--spacing-4);
	}

	.row-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--spacing-3);
	}

	.row-num {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		color: var(--color-accent);
	}

	.row-year {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		color: var(--color-muted);
	}

	.row-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		color: var(--color-text);
		letter-spacing: -0.01em;
		margin-bottom: var(--spacing-2);
		transition: color var(--transition-fast);
	}

	.project-row:hover .row-title {
		color: var(--color-accent);
	}

	.row-desc {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: 1.6;
		max-width: 640px;
		margin-bottom: var(--spacing-4);
	}

	.row-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.row-tags {
		display: flex;
		gap: var(--spacing-2);
		flex-wrap: wrap;
	}

	.row-tag {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		padding: 2px 8px;
		border-radius: 2px;
	}

	.row-arrow {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		transition: transform var(--transition-fast), color var(--transition-fast);
	}

	.project-row:hover .row-arrow {
		color: var(--color-accent);
		transform: translate(4px, -2px);
	}

	html[dir="rtl"] .project-row:hover .row-arrow {
		transform: translate(-4px, -2px);
	}

	/* ── Writing §02 ── */
	.section-writing {
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border);
	}

	.writing-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: var(--spacing-6);
		margin-bottom: var(--spacing-4);
	}

	.writing-card {
		display: block;
		text-decoration: none;
		padding: var(--spacing-6);
		border: 1px solid var(--color-border);
		transition: background var(--transition-base), border-color var(--transition-fast);
	}

	.writing-card:hover {
		background: var(--color-surface);
		border-color: var(--color-accent);
	}

	.feature-card {
		background: var(--color-surface);
	}

	.writing-side {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
	}

	.side-card {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.writing-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-3);
		flex-wrap: wrap;
	}

	.writing-tag {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.writing-date {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.1em;
		color: var(--color-muted);
	}

	.writing-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		color: var(--color-text);
		letter-spacing: -0.01em;
		line-height: 1.25;
		margin-bottom: var(--spacing-3);
	}

	.writing-title-sm {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.3;
		margin-bottom: var(--spacing-2);
	}

	.writing-dek {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: 1.6;
		margin-bottom: var(--spacing-4);
	}

	.writing-cta {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		display: inline-flex;
		align-items: center;
		gap: 4px;
		transition: gap var(--transition-fast);
	}

	.writing-card:hover .writing-cta {
		gap: 8px;
	}

	.writing-arrow {
		font-size: var(--font-size-base);
		color: var(--color-muted);
		margin-top: auto;
		transition: color var(--transition-fast), transform var(--transition-fast);
	}

	.writing-card:hover .writing-arrow {
		color: var(--color-accent);
		transform: translateX(4px);
	}

	html[dir="rtl"] .writing-card:hover .writing-arrow {
		transform: translateX(-4px);
	}

	/* ── About §03 ── */
	.section-about {
		border-bottom: 1px solid var(--color-border);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1.6fr;
		gap: var(--spacing-16);
		margin-bottom: var(--spacing-16);
	}

	.about-heading {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-8);
	}

	.info-list {
		display: flex;
		flex-direction: column;
	}

	.info-row {
		display: flex;
		justify-content: space-between;
		padding: var(--spacing-3) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.info-row dt {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.info-row dd {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
		text-align: end;
	}

	.info-row dd a {
		text-decoration: none;
		color: var(--color-text);
	}

	.info-row dd a:hover {
		color: var(--color-accent);
	}

	.status-available {
		color: #22c55e;
	}

	.about-bio p {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: 1.75;
		margin-bottom: var(--spacing-5);
	}

	.bio-dropcap::first-letter {
		font-family: "Playfair Display", Georgia, serif;
		font-size: 3.4em;
		font-weight: 700;
		float: left;
		line-height: 0.78;
		margin-right: 6px;
		margin-top: 4px;
		color: var(--color-accent);
	}

	html[dir="rtl"] .bio-dropcap::first-letter {
		float: right;
		margin-right: 0;
		margin-left: 6px;
	}

	/* Skills grid */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}

	.skill-group {
		padding: var(--spacing-5);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}

	.skill-group-title {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.skill-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.skill-badge {
		padding: 3px 10px;
		font-size: var(--font-size-xs);
		font-family: var(--font-mono);
		letter-spacing: 0.05em;
		border-radius: 2px;
		transition: border-color var(--transition-fast), color var(--transition-fast);
	}

	.badge-filled {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.badge-secondary {
		background: var(--color-bg-subtle);
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.badge-outline {
		background: transparent;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
	}

	.skill-badge:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* ── Contact §04 ── */
	.section-contact {
		background: var(--color-bg-subtle);
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
	}

	.contact-heading {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-5);
	}

	.contact-description {
		font-size: var(--font-size-base);
		color: var(--color-muted);
		line-height: 1.7;
		margin-bottom: var(--spacing-8);
	}

	.contact-links {
		display: flex;
		flex-direction: column;
	}

	.contact-link {
		display: flex;
		flex-direction: column;
		padding: var(--spacing-4) 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		transition: border-color var(--transition-fast);
	}

	.contact-link:hover {
		border-color: var(--color-accent);
	}

	.link-label {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: 3px;
	}

	.link-value {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-text);
		font-weight: 500;
		transition: color var(--transition-fast);
	}

	.contact-link:hover .link-value {
		color: var(--color-accent);
	}

	.form-heading {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		margin-bottom: var(--spacing-6);
		letter-spacing: -0.01em;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
	}

	.form-field {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.form-field label {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.form-field input,
	.form-field textarea {
		padding: var(--spacing-3) var(--spacing-4);
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-text);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0;
		transition: border-color var(--transition-fast);
	}

	.form-field input:focus,
	.form-field textarea:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	.form-field textarea {
		resize: vertical;
		min-height: 120px;
	}

	.form-error {
		padding: var(--spacing-3) var(--spacing-4);
		background: rgba(239, 68, 68, 0.08);
		border: 1px solid rgba(239, 68, 68, 0.25);
		color: #dc2626;
		font-size: var(--font-size-sm);
	}

	.form-success {
		padding: var(--spacing-8);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		text-align: center;
	}

	.form-success p {
		color: #22c55e;
		font-family: var(--font-serif);
		margin-bottom: var(--spacing-5);
	}

	/* ── Reveal animations ── */
	.reveal {
		opacity: 0;
	}

	.reveal.visible {
		opacity: 1;
	}

	.reveal-child,
	.reveal-item {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 0.55s ease, transform 0.55s ease;
	}

	.reveal.visible .reveal-child {
		opacity: 1;
		transform: translateY(0);
	}

	.reveal.visible .reveal-item {
		opacity: 1;
		transform: translateY(0);
		transition-delay: calc(var(--delay, 0) * 0.08s);
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal,
		.reveal-child,
		.reveal-item,
		.ticker-track {
			opacity: 1;
			transform: none;
			transition: none;
			animation: none;
		}
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.bilingual-lockup {
			gap: 20px;
		}

		.lockup-first,
		.lockup-last {
			font-size: clamp(28px, 7vw, 48px);
		}

		.lockup-first-ar,
		.lockup-last-ar {
			font-size: clamp(32px, 7.5vw, 52px);
		}

		.hero-body {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.hero-side {
			border-left: none;
			border-top: 1px solid var(--color-border);
			padding-left: 0;
			padding-top: var(--spacing-6);
			display: flex;
			gap: var(--spacing-8);
			align-items: flex-start;
		}

		html[dir="rtl"] .hero-side {
			border-right: none;
			padding-right: 0;
		}

		.hero-metrics {
			flex-direction: row;
			flex-wrap: wrap;
			gap: var(--spacing-5);
			border-top: none;
			padding-top: 0;
		}

		.writing-grid {
			grid-template-columns: 1fr;
		}

		.about-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.contact-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.skills-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 480px) {
		.bilingual-lockup {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: var(--spacing-4);
		}

		.lockup-latin { align-items: center; }
		.lockup-arabic { align-items: center; }

		.lockup-pivot {
			flex-direction: row;
			height: auto;
			width: 100%;
			justify-content: center;
		}

		.pivot-line {
			width: clamp(32px, 10vw, 60px);
			height: 1px;
		}

		.masthead-bar {
			flex-wrap: wrap;
			gap: 8px;
		}

		.skills-grid {
			grid-template-columns: 1fr;
		}
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 0.875rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 9999px;
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-lg);
	}

	.badge-dot {
		width: 8px;
		height: 8px;
		background: #22c55e;
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}

	.hero-name {
		font-family: var(--font-serif);
		font-size: clamp(3rem, 10vw, var(--font-size-5xl));
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-lg);
	}

	.last-name {
		color: var(--color-accent);
	}

	.hero-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		max-width: 600px;
		line-height: 1.6;
		margin-bottom: var(--spacing-md);
	}

	.hero-stack {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-family: var(--font-mono);
		margin-bottom: var(--spacing-xl);
	}

	.hero-cta {
		display: flex;
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-xl);
		flex-wrap: wrap;
		justify-content: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		font-size: var(--font-size-sm);
		font-weight: 500;
		border-radius: var(--radius);
		text-decoration: none;
		transition: all var(--transition-fast);
		cursor: pointer;
		border: none;
	}

	.btn-primary {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.btn-primary:hover {
		background: var(--color-accent);
	}

	.btn-secondary {
		background: var(--color-surface);
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.hero-social {
		display: flex;
		gap: var(--spacing-lg);
	}

	.hero-social a {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.hero-social a:hover {
		color: var(--color-accent);
	}

	/* Section Labels & Headers */
	.section-label {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		margin-bottom: var(--spacing-sm);
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
	}

	.section-header {
		margin-bottom: var(--spacing-2xl);
	}

	/* About Section */
	.about {
		padding: var(--spacing-4xl) var(--spacing-lg);
