---
import Base from "../../../layouts/Base.astro";
import { t, locales, type Locale, defaultLocale } from "../../../i18n/utils";

interface JobRecord {
	id: string;
	title: string;
	company: string | null;
	location: string | null;
	description_clean: string | null;
	ai_summary_ar: string | null;
	image_url: string | null;
	source_url: string | null;
	posted_date: string | null;
	deadline: string | null;
	telegraph_url: string | null;
	category: string | null;
	status: string;
	source: string;
	scraped_at: string;
	posted_at: string | null;
	word_count: number | null;
}

const { locale: localeParam } = Astro.params;
const locale: Locale = locales.includes(localeParam as Locale)
	? (localeParam as Locale)
	: defaultLocale;

if (!locales.includes(localeParam as Locale)) {
	return Astro.redirect(`/${defaultLocale}/jobs`, 302);
}

const page = Number(Astro.url.searchParams.get("page") ?? "1");
const limit = 20;

const apiBase = (Astro.locals as unknown as { runtime: { env: Record<string, string> } }).runtime.env.JOBS_API_URL ?? "";
let jobs: JobRecord[] = [];
let meta = { page: 1, total: 0, totalPages: 1, limit };

try {
	const res = await fetch(
		`${apiBase}/api/jobs?status=posted&limit=${limit}&page=${page}`,
	);
	if (res.ok) {
		const json = (await res.json()) as {
			data: JobRecord[];
			meta: typeof meta;
		};
		jobs = json.data;
		meta = json.meta;
	}
} catch {
	// network error — empty state renders
}

const jobHref = (job: JobRecord) => job.telegraph_url ?? job.source_url ?? "#";

const jobSummary = (job: JobRecord) =>
	locale === "ar"
		? (job.ai_summary_ar ?? job.description_clean)
		: job.description_clean;

const formatDate = (d: string | null) =>
	d
		? new Date(d).toLocaleDateString(locale === "ar" ? "ar-SA" : "en-US", {
				year: "numeric",
				month: "long",
				day: "numeric",
			})
		: null;
---

<Base
	title={t("jobs.title", locale)}
	description={t("jobs.description", locale)}
	locale={locale}
>
	<div class="jobs-page">
		<header class="page-header">
			<h1 class="page-title">{t("jobs.title", locale)}</h1>
			<p class="page-description">
				{meta.total}
				{t("jobs.count", locale)}
			</p>
		</header>

		{
			jobs.length === 0 ? (
				<p class="empty">{t("jobs.empty", locale)}</p>
			) : (
				<div class="jobs-list">
					{jobs.map((job) => (
						<article class="job-item">
							<a
								href={jobHref(job)}
								class="job-link"
								target="_blank"
								rel="noopener noreferrer"
							>
								<div class="job-meta">
									<span class="job-source">{job.source}</span>
									{job.location && (
										<>
											<span class="meta-dot" />
											<span>{job.location}</span>
										</>
									)}
									{job.deadline && (
										<>
											<span class="meta-dot" />
											<time>{formatDate(job.deadline)}</time>
										</>
									)}
								</div>
								<h2 class="job-title">{job.title}</h2>
								{job.company && <p class="job-company">{job.company}</p>}
								{jobSummary(job) && (
									<p class="job-summary">{jobSummary(job)}</p>
								)}
							</a>
						</article>
					))}
				</div>
			)
		}

		{
			meta.totalPages > 1 && (
				<nav class="pagination">
					{page > 1 && (
						<a href={`/${locale}/jobs?page=${page - 1}`} class="pagination-link">
							{t("jobs.prev", locale)}
						</a>
					)}
					<span class="pagination-info">
						{t("jobs.page", locale)} {page} / {meta.totalPages}
					</span>
					{page < meta.totalPages && (
						<a href={`/${locale}/jobs?page=${page + 1}`} class="pagination-link">
							{t("jobs.next", locale)}
						</a>
					)}
				</nav>
			)
		}
	</div>
</Base>

<style>
	.jobs-page {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: var(--font-size-4xl);
		font-weight: 500;
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		font-family: var(--font-serif);
		font-style: italic;
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.jobs-list {
		display: flex;
		flex-direction: column;
	}

	.job-item {
		padding: var(--spacing-8) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.job-item:first-child {
		padding-top: 0;
	}

	.job-item:last-child {
		border-bottom: none;
	}

	.job-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.job-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2);
	}

	.job-source {
		font-family: var(--font-mono);
		color: var(--color-accent);
		text-transform: uppercase;
		font-size: var(--font-size-xs);
		letter-spacing: 0.08em;
	}

	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
		flex-shrink: 0;
	}

	.job-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		line-height: var(--leading-snug);
		letter-spacing: -0.02em;
		margin-bottom: var(--spacing-1);
		transition: color var(--transition-fast);
	}

	.job-link:hover .job-title {
		color: var(--color-accent);
	}

	.job-company {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-2);
	}

	.job-summary {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-6);
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border);
	}

	.pagination-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.pagination-link:hover {
		text-decoration: underline;
	}

	.pagination-info {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	@media (max-width: 600px) {
		.jobs-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.job-title {
			font-size: var(--font-size-xl);
		}
	}
</style>
