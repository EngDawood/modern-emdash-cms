---
export const prerender = false;

import { getEmDashEntry, search } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { t, locales, type Locale, defaultLocale } from "../../i18n/utils";

const { locale: localeParam } = Astro.params;
const locale: Locale = locales.includes(localeParam as Locale)
	? (localeParam as Locale)
	: defaultLocale;

if (!locales.includes(localeParam as Locale)) {
	return Astro.redirect(`/${defaultLocale}/search${Astro.url.search}`, 302);
}

const query = Astro.url.searchParams.get("q")?.trim() || "";

const searchRes = query
	? await search(query, { collections: ["posts"], locale, limit: 100 })
	: { items: [] };

const results = [];
if (query && searchRes.items.length > 0) {
	for (const item of searchRes.items) {
		if (item.collection === "posts" && item.slug) {
			const { entry } = await getEmDashEntry("posts", item.slug, { locale });
			if (entry) {
				results.push(entry);
			}
		}
	}
}
---

<Base
	title={query ? `${t("search.title", locale)}: ${query}` : t("search.title", locale)}
	description={t("search.description", locale)}
	locale={locale}
>
	<section class="search-page">
		<h1 class="search-title">{t("search.title", locale)}</h1>

		<form method="get" action={`/${locale}/search`} class="search-form">
			<input
				type="search"
				name="q"
				value={query}
				placeholder={t("search.placeholder", locale)}
				class="search-input"
				autofocus
			/>
			<button type="submit" class="search-button">{t("search.button", locale)}</button>
		</form>

		{
			query && (
				<p class="search-summary">
					{results.length === 0
						? `${t("search.noResults", locale)} "${query}"`
						: `${t("search.resultsSummary", locale).replace("{count}", String(results.length))} "${query}"`}
				</p>
			)
		}

		{
			results.length > 0 && (
				<div class="search-results">
					{results.map((post) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/${locale}/blog/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							locale={locale}
						/>
					))}
				</div>
			)
		}

		{!query && <p class="search-hint">{t("search.hint", locale)}</p>}
	</section>
</Base>

<style>
	.search-page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.search-title {
		font-size: var(--font-size-2xl);
		font-family: var(--font-serif);
		font-weight: 500;
		margin-bottom: var(--spacing-6);
	}

	.search-form {
		display: flex;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-8);
	}

	.search-input {
		flex: 1;
		padding: var(--spacing-2) var(--spacing-4);
		font-size: var(--font-size-base);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
	}

	.search-input:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	.search-button {
		padding: var(--spacing-2) var(--spacing-6);
		font-size: var(--font-size-base);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border: none;
		border-radius: var(--radius);
		cursor: pointer;
		font-weight: 500;
	}

	.search-button:hover {
		background: var(--color-accent-hover);
	}

	.search-summary {
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.search-hint {
		color: var(--color-muted);
	}

	.search-results {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
	}
</style>
